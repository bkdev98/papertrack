# ─── Copy to .env and adjust ───────────────────────────────────────────────
# Local dev uses the docker-compose Postgres on host port 5433 (5432 is taken).
DATABASE_URL=postgres://postgres:postgres@localhost:5433/papertrack_app

# API server
PORT=3100
NODE_ENV=development

# Session / auth — the shared unlock password and a secret to sign the cookie.
# ENFORCED: when NODE_ENV=production the app refuses to boot unless APP_PASSWORD
# is changed from the default and SESSION_SECRET is a non-default string ≥16 chars.
APP_PASSWORD=papertrack
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# CORS: the web dev origin (only needed when web + api run on different ports)
WEB_ORIGIN=http://localhost:5174

# ─── File storage ──────────────────────────────────────────────────────────
# Driver auto-selects: if the R2_* vars below are all set → Cloudflare R2,
# otherwise → local disk at STORAGE_LOCAL_DIR (dev / single-node fallback).
STORAGE_LOCAL_DIR=./storage-data

# Cloudflare R2 (S3-compatible). Leave blank to use the local driver.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=papertrack
# Optional public base URL if the bucket is served through a CDN/custom domain.
R2_PUBLIC_BASE_URL=

# ─── AI (optional) ─────────────────────────────────────────────────────────
# Personal Claude Code OAuth token (run `claude setup-token`). When set, the
# overview sticky note is generated by Claude, grounded in the computed
# deadline/aging/fee signals (no author or settlement data is ever sent). It's an
# OAuth token tied to your Claude subscription — no metered API billing. Leave
# blank to use the built-in deterministic nudge — same auto-select pattern as R2
# above: set → on, unset → local fallback.
CLAUDE_CODE_OAUTH_TOKEN=
# Optional model override (fast, low-cost default).
AI_MODEL=claude-haiku-4-5

# ─── Web (build-time) ──────────────────────────────────────────────────────
# In production the API serves the built SPA, so this defaults to same-origin.
# For split dev servers, the web app calls the API at this base.
VITE_API_BASE=http://localhost:3100
